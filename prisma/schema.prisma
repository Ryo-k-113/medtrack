// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



// ユーザー情報
model User {
  id              Int      @id @default(autoincrement()) 
  supabaseUserId  String   @unique
  email           String   @unique
  role            Role   @default(USER) 
  createdAt       DateTime @default(now()) 
  updatedAt       DateTime @updatedAt

  // リレーション
  BookmarkDrugs   BookmarkDrug[]
}

enum Role {
  USER
  ADMIN
}

// ユーザーがブックマークした医薬品
model BookmarkDrug {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now()) 
  updatedAt       DateTime @updatedAt
  
  // 外部キー (Int に修正)
  UserId          Int
  DrugId          Int
  
  // リレーション
  User            User     @relation(fields: [UserId], references: [id])
  Drug            Drug     @relation(fields: [DrugId], references: [id])
  
  // 複合キー (オプション: ユーザーと医薬品の組み合わせで一意にする場合)
  @@unique([UserId, DrugId])
}


// 医薬品の基本情報
model Drug {
  id                        Int      @id @default(autoincrement()) 
  name                      String        // 製品名
  price                     Decimal?      // 薬価
  drugPriceListingCode      String?       // 薬価収載コード
  yjCode                    String        // YJコード
  isSelectMedical           Boolean?      // 選定療養制度の対象
  isAuthorizedGeneric       Boolean?      // オーソライズドジェネリック 
  packageInsertUrl          String?       // 添付文書URL
  productType               ProductType   // 製品区分
  transitionalMeasuresDate  DateTime?     //経過措置日
  createdAt                 DateTime @default(now()) 
  updatedAt                 DateTime @updatedAt
  
  // 外部キー 
  UnitId                  Int
  GenericNameId           Int
  ManufacturingCompanyId  Int
  SalesCompanyId          Int
  
  
  // リレーション
  Unit                    Unit                   @relation(fields: [UnitId], references: [id])
  GenericName             GenericName            @relation(fields: [GenericNameId], references: [id])

  //製造販売元。開発上の便宜として manufacturing と命名。
  ManufacturingCompany    PharmaceuticalCompany  @relation("Manufacture", fields: [ManufacturingCompanyId], references: [id])

  //販売元。開発上の便宜として sales と命名
  SalesCompany            PharmaceuticalCompany  @relation("Sales", fields: [SalesCompanyId], references: [id])   

  //複合キー：YJコードとメーカーの組み合わせで一意に
  @@unique([yjCode, SalesCompanyId])     
  
  BookmarkDrugs           BookmarkDrug[]
  PackageUnits            PackageUnit[]
}

enum ProductType {
  BRAND_NAME            // 先発品
  QUASI_BRAND_NAME      // 準先発品
  GENERIC               // 後発品
  OTHER                 // その他
}



// 医薬品の包装単位
model PackageUnit {
  id                        Int      @id @default(autoincrement()) 
  name                      String
  gs1SalesCode              String?  @unique   // 販売包装単位GS1コード
  gs1DispensingCode         String?  @unique   // 調剤包装単位GS1コード
  hotCode                   String?  @unique   // HOTコード (基準番号)
  janCode                   String?  @unique   // JANコード
  unifiedCode               String   @unique   // 統一商品コード

  currentShippingStatus     CurrentShippingStatus 
  salesTransferDate         DateTime?          // 販売移管日
  discontinuedDate          DateTime?          // 販売中止日
  publishStatus             PublishStatus  
  createdAt                 DateTime @default(now()) 
  updatedAt                 DateTime @updatedAt    

  // 外部キー 
  DrugId                    Int
  
  // リレーション
  Drug                      Drug                   @relation(fields: [DrugId], references: [id], onDelete: Cascade )
  AnnounceHistories         AnnounceHistory[]
}

// 公開ステータス
enum PublishStatus {
  DRAFT
  PUBLISHED
}

// 現在の出荷状況
enum CurrentShippingStatus {
  NORMAL_SHIPMENT    // 通常出荷
  LIMITED_SHIPMENT   // 限定出荷
  SHIPMENT_SUSPENDED // 供給停止
  DISCONTINUED_SALE  // 販売中止
}


// 各包装の出荷状況履歴
model AnnounceHistory {
  id                Int      @id @default(autoincrement()) 
  announcedDate     DateTime?      // 告示日
  effectiveDate     DateTime?      // 適用日
  announceType      AnnounceType?    
  publishStatus     AnnouncePublishStatus @default(PUBLISHED)
  processStatus     ProcessStatus @default(PENDING) 
  createdAt         DateTime @default(now()) 
  updatedAt         DateTime @updatedAt
  
  
  // 外部キー 
  PackageUnitId          Int
  
  // リレーション
  PackageUnit            PackageUnit @relation(fields: [PackageUnitId], references: [id], onDelete: Cascade)

  // インデックス（定期実行用）
  @@index([effectiveDate, processStatus, publishStatus])
}

// 告示情報の公開ステータス
enum AnnouncePublishStatus {
  DRAFT      // 下書き
  PUBLISHED  // 公開
  INACTIVE   // 非表示
}

// 告示タイプ
enum AnnounceType {
  NORMAL_SHIPMENT    // 通常出荷
  LIMITED_SHIPMENT   // 限定出荷
  SHIPMENT_SUSPENDED // 供給停止
  DISCONTINUED_SALE  // 販売中止
  TRANSFER_OF_SALE   // 販売移管
}

// 定期実行ステータス
enum ProcessStatus {
  PENDING     // 適用待ち（デフォルト）
  COMPLETED   // 適用完了
}


// 規格単位
model Unit {
  id          Int      @id @default(autoincrement()) 
  name        String
  createdAt   DateTime @default(now()) 
  updatedAt   DateTime @updatedAt 
  
  // リレーション
  Drugs     Drug[]
}



// 成分名
model GenericName {
  id          Int      @id @default(autoincrement()) 
  name        String
  createdAt   DateTime @default(now()) 
  updatedAt   DateTime @updatedAt 
  
  // リレーション
  Drugs     Drug[]
}



// 製薬会社 
model PharmaceuticalCompany {
  id          Int      @id @default(autoincrement()) 
  name        String
  createdAt   DateTime @default(now()) 
  updatedAt   DateTime @updatedAt 
  
  // リレーション
  ManufacturedDrugs  Drug[] @relation("Manufacture") 
  SoldDrugs          Drug[] @relation("Sales")      
}


// 定期実行の処理履歴
model BatchProcessingLog {
  id             Int            @id @default(autoincrement())
  jobType        BatchJobType
  status         BatchJobStatus
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  failedAt       DateTime?
  errorMessage   String?
  processedCount Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum BatchJobType {
  UPDATE_SHIPPING_STATUS
}

enum BatchJobStatus {
  RUNNING   // 実行中
  COMPLETED // 完了
  FAILED    // 失敗（全体中断）
}
