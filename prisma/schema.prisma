
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



// ユーザー情報
model User {
  id             Int       @id @default(autoincrement())
  supabaseUserId String    @unique @map("supabase_user_id")
  email          String    @unique
  role           Role      @default(USER)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  
  // リレーション
  BookmarkDrugs   BookmarkDrug[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ユーザーがブックマークした医薬品
model BookmarkDrug {
  id         Int       @id @default(autoincrement())
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // 外部キー
  userId     Int       @map("user_id")
  drugId     Int       @map("drug_id")

  // リレーション
  user  User  @relation(fields: [userId], references: [id])
  drug  Drug  @relation(fields: [drugId], references: [id])

  // 複合キー (ユーザーと医薬品の組み合わせで一意に)
  @@unique([userId, drugId])

  @@map("bookmark_drugs")
}


// 医薬品の基本情報
model Drug {
  id                       Int      @id @default(autoincrement())
  name                     String   
  price                    Decimal? // 薬価
  drugPriceListingCode     String?  @map("drug_price_listing_code") // 薬価収載コード
  yjCode                   String   @map("yj_code") 
  isSelectMedical          Boolean? @map("is_select_medical") 
  isAuthorizedGeneric      Boolean? @map("is_authorized_generic") 
  packageInsertUrl         String?  @map("package_insert_url") //添付文書URL
  productType              ProductType  @map("product_type") 
  transitionalMeasuresDate DateTime?  @map("transitional_measures_date") // 経過措置日 
  createdAt                DateTime   @default(now()) @map("created_at")
  updatedAt                DateTime   @updatedAt @map("updated_at")

  // 外部キー
  unitId                   Int  @map("unit_id")
  genericNameId            Int  @map("generic_name_id")
  manufacturingCompanyId   Int  @map("manufacturing_company_id")
  salesCompanyId           Int  @map("sales_company_id")
  
  
  // リレーション
  Unit                    Unit  @relation(fields: [UnitId], references: [id])
  GenericName             GenericName  @relation(fields: [GenericNameId], references: [id])

  //製造販売元。開発上の便宜として manufacturing と命名。
  ManufacturingCompany    PharmaceuticalCompany  @relation("Manufacture", fields: [ManufacturingCompanyId], references: [id])

  //販売元。開発上の便宜として sales と命名
  SalesCompany            PharmaceuticalCompany  @relation("Sales", fields: [SalesCompanyId], references: [id])   

  //複合キー：YJコードとメーカーの組み合わせで一意に
  @@unique([yjCode, SalesCompanyId])
  @@map("drugs")     
  
  BookmarkDrugs           BookmarkDrug[]
  PackageUnits            PackageUnit[]
}

// 製品区分
enum ProductType {
  BRAND_NAME            // 先発品
  QUASI_BRAND_NAME      // 準先発品
  GENERIC               // 後発品
  OTHER                 // その他

  @@map("product_type")
}



// 医薬品の包装単位
model PackageUnit {
  id                    Int       @id @default(autoincrement())
  name                  String
  gs1SalesCode          String?   @unique @map("gs1_sales_code") // 販売包装単位GS1コード
  gs1DispensingCode     String?   @unique @map("gs1_dispensing_code") // 調剤包装単位GS1コード
  hotCode               String?   @unique @map("hot_code") // HOTコード (基準番号)
  janCode               String?   @unique @map("jan_code") // JANコード
  unifiedCode           String    @unique @map("unified_code") // 統一商品コード

  currentShippingStatus CurrentShippingStatus  @map("current_shipping_status")
  salesTransferDate     DateTime?  @map("sales_transfer_date") // 販売移管日
  discontinuedDate      DateTime?  @map("discontinued_date") // 販売中止日
  publishStatus         PublishStatus  @map("publish_status")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  // 外部キー
  drugId                Int  @map("drug_id")
  
  // リレーション
  Drug                  Drug @relation(fields: [DrugId], references: [id], onDelete: Cascade )
  AnnounceHistories         AnnounceHistory[]

  @@map("package_units")
}

// 公開ステータス
enum PublishStatus {
  DRAFT
  PUBLISHED

  @@map("publish_status")
}

// 現在の出荷状況
enum CurrentShippingStatus {
  NORMAL_SHIPMENT    // 通常出荷
  LIMITED_SHIPMENT   // 限定出荷
  SHIPMENT_SUSPENDED // 供給停止
  DISCONTINUED_SALE  // 販売中止

  @@map("current_shipping_status")
}


// 各包装の出荷状況履歴
model AnnounceHistory {
  id              Int                     @id @default(autoincrement())
  announcedDate   DateTime?               @map("announced_date") // 告示日
  effectiveDate   DateTime?               @map("effective_date") // 適用日
  announceType    AnnounceType?           @map("announce_type")
  publishStatus   AnnouncePublishStatus   @default(PUBLISHED) @map("publish_status")
  processStatus   ProcessStatus           @default(PENDING) @map("process_status")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  // 外部キー
  packageUnitId Int @map("package_unit_id")
  
  // リレーション
  PackageUnit            PackageUnit @relation(fields: [PackageUnitId], references: [id], onDelete: Cascade)

  // インデックス（定期実行用）
  @@index([effectiveDate, processStatus, publishStatus])

  @@map("announce_histories")
}

// 告示情報の公開ステータス
enum AnnouncePublishStatus {
  DRAFT      // 下書き
  PUBLISHED  // 公開
  INACTIVE   // 非表示

  @@map("announce_publish_status")
}

// 告示タイプ
enum AnnounceType {
  NORMAL_SHIPMENT    // 通常出荷
  LIMITED_SHIPMENT   // 限定出荷
  SHIPMENT_SUSPENDED // 供給停止
  DISCONTINUED_SALE  // 販売中止
  TRANSFER_OF_SALE   // 販売移管

  @@map("announce_type")
}

// 定期実行ステータス
enum ProcessStatus {
  PENDING     // 適用待ち（デフォルト）
  COMPLETED   // 適用完了

  @@map("process_status")
}


// 規格単位
model Unit {
  id          Int        @id @default(autoincrement()) 
  name        String
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at") 
  
  // リレーション
  Drugs     Drug[]

  @@map("units")
}



// 成分名
model GenericName {
  id          Int        @id @default(autoincrement()) 
  name        String
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at") 
  
  // リレーション
  Drugs     Drug[]

  @@map("generic_names")
}



// 製薬会社 
model PharmaceuticalCompany {
  id          Int        @id @default(autoincrement()) 
  name        String 
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  
  // リレーション
  ManufacturedDrugs  Drug[]  @relation("Manufacture") 
  SoldDrugs          Drug[]  @relation("Sales")  

  @@map("pharmaceutical_companies")    
}


// 定期実行の処理履歴
model BatchProcessingLog {
  id             Int            @id @default(autoincrement())
  jobType        BatchJobType   @map("job_type")
  status         BatchJobStatus
  startedAt      DateTime       @default(now()) @map("started_at")
  completedAt    DateTime?      @map("completed_at")
  failedAt       DateTime?      @map("failed_at")
  errorMessage   String?        @map("error_message")
  processedCount Int            @default(0) @map("processed_count")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("batch_processing_logs")
}

enum BatchJobType {
  UPDATE_SHIPPING_STATUS

  @@map("batch_job_type")
}

enum BatchJobStatus {
  RUNNING   // 実行中
  COMPLETED // 完了
  FAILED    // 失敗（全体中断）

  @@map("batch_job_status")
}
